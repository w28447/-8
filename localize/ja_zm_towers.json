    "hash_6e20bae2ef2a05f5": "^1スカーレット: ^7あたしのとこへおいで、かわいこちゃん",
    "hash_6e214d34708e5079": "^1ショー: ^7あのチビの事を、私は本当に気に入ってきた！",
