    "hash_7d98df335e16c966": "^1Misty: ^7One, two, three, four...you always count your exits. Even when you're outside.",
    "hash_7d98e0335e16cb19": "^1Marlton: ^7Remarkable that the ship is still burning -- but not even in the top five strangest things here.",
    "hash_7d98ea335e16dc17": "^1Stuhlinger: ^7Not sure why, but...I'm really feeling kind of optimistic about this whole \"Agarthan Device\" thing.",
    "hash_7dc99cea8e1fef65": "^1Stuhlinger: ^7This better be useful...",
    "hash_7dc99dea8e1ff118": "^1Misty: ^7I got this. Literally.",
    "hash_7dc99eea8e1ff2cb": "^1Marlton: ^7Time is of the essence, after all!",
