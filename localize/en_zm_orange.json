    "hash_7345657a631305a1": "^1Russman: ^7Snowball bazooka! Russman approves!",
    "hash_7348e37a63161192": "^1Misty: ^7Ice-ta la vista!",
    "hash_7348e47a63161345": "^1Marlton: ^7If you can't stand the cold, get out of the tundra!",
    "hash_7348e67a631616ab": "^1Stuhlinger: ^7Ha! Iced your bony ass!",
    "hash_735af3276065ebf9": "^1Stuhlinger: ^7I recognize that name. He's Richtofen's boss, I think.",
    "hash_735afc276065fb44": "^1Misty: ^7Hey Stuhlinger, this is one of your German buddy's crew?",
    "hash_735afd276065fcf7": "^1Marlton: ^7I do believe we have a new ally. Seems friendly enough...",
    "hash_73650627606e60c7": "^1Russman: ^7Nikolai, huh? I hope you can help us find this \"Agatha\" contraption.",
    "hash_7365aa903d131f99": "^1Misty: ^7Well, I for one am glad to not be wearing my old gear - I'd be a Misty shaped popsicle by now! Ever had ice in your belly button?",
    "hash_7396b6b813ecea36": "^1Marlton: ^7I should show this off to Misty.",
    "hash_7396b7b813ecebe9": "^1Misty: ^7Let's see just how much punch I packed...",
    "hash_7396c0b813ecfb34": "^1Stuhlinger: ^7Oh, yeah. Come to poppa.",
    "hash_7399c5b813ef398a": "^1Russman: ^7Well I ain't leavin' that lyin' around--!",
    "hash_73d03eee139884bc": "^1Russman: ^7Rot-gobblers in lab coats. Must be the brains of the operation.",
    "hash_73d07c364a8695e5": "^1Stuhlinger: ^7That woke you up didn't it? Right before it killed you!",
    "hash_73d07d364a869798": "^1Misty: ^7You see that? I'm the one leading the charge!",
    "hash_73d07e364a86994b": "^1Marlton: ^7I wonder if Nikolai had any hand in creating this? And I'm talking about Tesla -- not the Russian one!",
    "hash_73da47ee13a0e88c": "^1Marlton: ^7Science without ethics yields...these things right here.",
    "hash_73da48ee13a0ea3f": "^1Misty: ^7Looks like the scientists got caught in their own experiment. Poetic justice much?",
    "hash_73da4dee13a0f2be": "^1Stuhlinger: ^7Looks like the mad scientists became part of their own experiment.",
    "hash_73db07364a8fd69b": "^1Russman: ^7Who's next? Assumin' Russman's got more left in the tank!",
    "hash_73eb56942aee345c": "^1Stuhlinger: ^7",
    "hash_74177f500c7f0832": "^1Samantha: ^7I'm having fun, und you can't stop me!",
