    "hash_28ea515ade07dde": "Get to Specimen Storage!",
    "hash_29d9edb73598fbc": "^1Misty: ^7Y'know I used to work construction? Did a lotta odd jobs before the world turned to shit.",
    "hash_29d9fdb7359916f": "^1Marlton: ^7This is futile -- the reanimate equivalent of a speed bump...",
    "hash_29da5db73599ba1": "^1Stuhlinger: ^7What am I buying myself here? Like ten seconds? I'll take it.",
