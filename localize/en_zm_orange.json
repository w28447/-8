    "hash_2d6f521128cbca9": "^1Misty: ^7Oh, Marlton, this just ain't your day, is it?",
    "hash_2d6fe21128ccbf4": "^1Stuhlinger: ^7Stop crying, Brain-box. This ought to get you back to your normal, useless self.",
    "hash_2da0321128f0a4a": "^1Russman: ^7No layin' down on the job, big-brain. Gonna take all of us to survive this.",
