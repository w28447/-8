    "hash_466e72c5bbb4fe7e": "^1Stuhlinger: ^7Here we go again...",
    "hash_466f31b8211c8354": "^1Apothicon Blood: ^7Othna, where mountains throw.",
    "hash_4692cf6e171984f0": "^1Marlton: ^7Wow! I am a legitimate death-dealer today!",
    "hash_469cc7a3cfe99107": "^1Marlton: ^7I'm just scared, Misty. I like understanding things and these days I don't understand almost anything! Are we really going to be okay? How can we be sure?!",
    "hash_46ab41f7d16c54a5": "^1Russman: ^7Somethin' tells me this thing is gonna explode...only not the way I like.",
    "hash_46aebff7d16f6096": "^1Misty: ^7Hey, ghost-girl, you in there? Got a question about the music... Do you take requests...?",
    "hash_46aec0f7d16f6249": "^1Marlton: ^7Forces of Darkness! Beware my mighty music box! Yeah, that doesn't really work, does it?",
    "hash_46aecaf7d16f7347": "^1Stuhlinger: ^7Is there a reason my hair stands on end when I touch this music box? Yeeesh!",
    "hash_46d9533deecbd780": "^1Misty: ^7Death by Russian Granny!",
    "hash_46d9543deecbd933": "^1Marlton: ^7Mother used to collect Matryoshkas. She used to blow up, too.",
