    "hash_731c436c01f21523": "^1Russman: ^7Get yer mangy self back to Heck!",
    "hash_731eadf333dcf0fc": "^1Misty: ^7Nah. I'm good. Somebody else can have this.",
    "hash_731eaef333dcf2af": "^1Marlton: ^7I have determined that this item is... up for grabs!",
    "hash_731eb4f333dcfce1": "^1Stuhlinger: ^7One man's trash is another man's treasure, right? So who want my trash?",
    "hash_73223d1456fa8047": "^1Stuhlinger: ^7I'd give my freakin' mustache for one more bullet.",
    "hash_732927f333e614cf": "^1Russman: ^7No, thank you, Devil Box. Don't mind if someone else helps themselves, though.",
    "hash_733d7eca709eac9a": "^1Misty: ^7\"Bye-bye,\" my eye. I'm huntin' you down, Box!",
